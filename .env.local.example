# file: .env.local.example — CLAUDE.md §6.1 唯一真源；新增 env 必须同步此文件
# Claude Code 模式：单 LLMClient 走 Anthropic Messages 协议（minimax / Kimi / 智谱 等都提供 Anthropic-compat 入口）

# ---- 主对话 LLM（L3 翻译用）----
LLM_PROVIDER=minimax                          # 仅 audit log tag（§11.10），不进 if/else
LLM_MODEL=MiniMax-M2.7
LLM_BASE_URL=https://api.minimaxi.com/anthropic
LLM_API_KEY=                                  # 走 Bearer Authorization；minimax token 形如 sk-cp-...

# ---- Vision（OCR 用，单独一套 endpoint）----
# P0 OCR 是 🟡 tier 不阻塞主链；激活时确认 minimax 实际 vision endpoint/model 再填
VISION_PROVIDER=minimax
VISION_MODEL=
VISION_BASE_URL=
VISION_API_KEY=

# ---- Fallback 链（一档失败自动切，可选；留空则不启用）----
# 注意：fallback provider 须同样支持 Anthropic Messages 协议（如 Kimi K2、智谱 GLM）
# DeepSeek 当前只 OpenAI 兼容，要做 fallback 需要单独 wrap，P0 暂不做
LLM_FALLBACK_PROVIDER=
LLM_FALLBACK_MODEL=
LLM_FALLBACK_BASE_URL=
LLM_FALLBACK_API_KEY=

# ---- 运行环境 ----
NEXT_PUBLIC_APP_ENV=dev                       # dev | staging | prod

# ---- Demo 模式（CLAUDE.md §11.11 DemoBanner 门闸）----
# 1 = 开启 Demo Banner 注入（未过审规则会显示"原型未临床验证"横幅）
# 0 = 关闭（仅所有触中规则均 reviewerCredential != self-review 时可用）
NEXT_PUBLIC_DEMO_MODE=1

# ---- 审计日志 ----
AUDIT_LOG_DIR=./var/audit
